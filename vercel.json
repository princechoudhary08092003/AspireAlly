{
  "installCommand": "npm install && npm install --prefix server && npm install --include=dev --prefix client",
  "buildCommand": "npm --prefix client run build",
  "outputDirectory": "client/dist",
  "framework": null,
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/index.js" },
    { "handle": "filesystem" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}
