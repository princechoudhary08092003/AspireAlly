# Dependencies
node_modules/
*/node_modules/

# Environment — never commit real secrets
.env
server/.env
client/.env.local
# .env.production is safe to commit (only has the API URL, no secrets)

# Database (local SQLite)
*.sqlite
*.sqlite3
*.db

# Build output
client/dist/
client/dist-ssr/

# Logs
*.log
npm-debug.log*

# OS
.DS_Store
Thumbs.db

# Editor
.vscode/
.idea/

# Uploads (local files)
server/uploads/*
!server/uploads/.gitkeep
