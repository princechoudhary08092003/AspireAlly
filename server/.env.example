PORT=5000
NODE_ENV=development

# JWT
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production

# SQLite (local dev) — no extra config needed, file auto-created
# For MySQL (Hostinger production), set these:
DB_DIALECT=sqlite
DB_HOST=localhost
DB_PORT=3306
DB_NAME=mentorpath
DB_USER=root
DB_PASSWORD=

# Razorpay
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret

# Client URL (for CORS)
CLIENT_URL=http://localhost:5173

# Admin default credentials (first run only)
ADMIN_EMAIL=admin@mentorpath.com
ADMIN_PASSWORD=Admin@123
